{
  "info": { "name": "Karlo Services - Pricing and Availability", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "serviceId", "value": "replace-with-service-id" },
    { "key": "serviceSlug", "value": "pan-card" }
  ],
  "item": [
    {
      "name": "Public service response is normalized",
      "request": { "method": "GET", "url": "{{baseUrl}}/services/{{serviceSlug}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('normalized business fields exist', () => { const s = pm.response.json().service; pm.expect(s.pricing).to.be.an('object'); pm.expect(s.estimatedProcessingTime).to.be.an('object'); pm.expect(s.availabilityStatus).to.be.a('string'); });"] } }]
    },
    {
      "name": "Admin updates fixed pricing and backend calculates total",
      "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "x-dev-user-id", "value": "postman-admin" }, { "key": "x-dev-role", "value": "admin" }], "body": { "mode": "raw", "raw": "{\n  \"pricing\": {\n    \"governmentFee\": 107,\n    \"serviceCharge\": 50,\n    \"totalAmount\": 99999,\n    \"pricingMode\": \"fixed\",\n    \"pricingNote\": \"\"\n  }\n}" }, "url": "{{baseUrl}}/admin/services/{{serviceId}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('untrusted total is overwritten', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().service.pricing.totalAmount).to.eql(157); });"] } }]
    },
    {
      "name": "Admin marks service coming soon",
      "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "x-dev-user-id", "value": "postman-admin" }, { "key": "x-dev-role", "value": "admin" }], "body": { "mode": "raw", "raw": "{\n  \"availabilityStatus\": \"coming_soon\",\n  \"availabilityMessage\": \"This service will be available soon.\"\n}" }, "url": "{{baseUrl}}/admin/services/{{serviceId}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('availability saves', () => { pm.response.to.have.status(200); pm.expect(pm.response.json().service.availabilityStatus).to.eql('coming_soon'); });"] } }]
    },
    {
      "name": "Unavailable application is rejected",
      "request": { "method": "POST", "header": [{ "key": "x-dev-user-id", "value": "postman-customer" }, { "key": "x-dev-role", "value": "customer" }, { "key": "Idempotency-Key", "value": "postman-unavailable-{{$guid}}" }], "body": { "mode": "formdata", "formdata": [] }, "url": "{{baseUrl}}/applications/{{serviceSlug}}" },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('backend rejects unavailable service before form processing', () => { pm.response.to.have.status(400); pm.expect(pm.response.json().message).to.include('available'); });"] } }]
    }
  ]
}
