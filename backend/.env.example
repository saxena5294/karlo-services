PORT=5000
NODE_ENV=development
DEV_AUTH_ENABLED=true
# Supported roles: customer, partner, expert, admin
# Optional recipient for application-submitted admin notifications.
DEV_ADMIN_USER_ID=
MONGO_URI=mongodb://127.0.0.1:27017/karlo
FRONTEND_URL=http://localhost:5173
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_REAL_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_REAL_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_REAL_API_SECRET
# Mobile verification. Production requires strong independent secrets.
OTP_HASH_SECRET=
OTP_TOKEN_SECRET=
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=

# Supported providers: turnstile, recaptcha. Production submissions fail closed when absent.
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
